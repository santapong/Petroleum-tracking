# On Vercel/serverless, use a pooled connection string (Neon pooler / Supabase pgbouncer)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/petroleum_tracking"
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-secret"
# Not needed on Vercel (host is auto-detected); set it for local/self-hosted runs
AUTH_URL="http://localhost:3000"

# EPPO (Energy Policy and Planning Office, Thailand) — used by /api/admin/sync/prices
EPPO_API_BASE="https://api.eppo.go.th"
EPPO_CATALOG_BASE="https://catalog.eppo.go.th"
